{
  "name": "md-copy",
  "displayName": "Markdown Copy",
  "description": "Adds copy buttons to the built-in Markdown preview — copy the entire file or individual code blocks.",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "CalvinWan0101",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CalvinWan0101/md-copy"
  },
  "bugs": {
    "url": "https://github.com/CalvinWan0101/md-copy/issues"
  },
  "homepage": "https://github.com/CalvinWan0101/md-copy",
  "engines": {
    "vscode": "^1.80.0"
  },
  "files": [
    "LICENSE",
    "readme.md",
    "media",
    "out"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-copy.copyMarkdown",
        "title": "Copy Markdown",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "md-copy.copyMarkdown",
          "when": "activeWebviewPanelId == 'markdown.preview'",
          "group": "navigation"
        },
        {
          "command": "md-copy.copyMarkdown",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "markdown.previewScripts": [
      "./media/preview.js"
    ],
    "markdown.previewStyles": [
      "./media/preview.css"
    ],
    "markdown.markdownItPlugins": true
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.5.0"
  }
}
